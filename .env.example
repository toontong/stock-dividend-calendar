# CalDAV credentials for WPS Calendar
# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit real secrets.

CALDAV_USERNAME=your_username_here
CALDAV_PASSWORD=your_password_here

# LLM 股票分析 (optional, only needed with --analyze)
# 支持任何 OpenAI-compatible 厂商 (OpenAI, DeepSeek, Moonshot, Ollama 等)
# 环境变量优先于 config/llm.json 中的对应字段
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your_api_key_here
